# Copy to .env (DO NOT commit secrets to version control)
# Supabase (frontend/public)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Public URL used by Supabase email confirmation redirects
# Set this to the deployed app URL in production (Netlify / custom domain).
VITE_SITE_URL=

# Mercado Pago access token for server-side Supabase function
# Put the client's private token here (do NOT commit).
MERCADOPAGO_ACCESS_TOKEN_CLIENT=APP_USR-4466145482995917-062215-3e0fd3a688a1cc6b20a93e7207f59e22-2558276524

# Optional: fallback token (developer)
MERCADOPAGO_ACCESS_TOKEN=

# Pixel is included directly in index.html when provided
